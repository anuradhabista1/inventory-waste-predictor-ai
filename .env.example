# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Application
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Auth credentials (set strong passwords before any non-local deployment)
ADMIN_PASSWORD=admin
VIEWER_PASSWORD=viewer

# Session expiry in seconds (default 8 hours = 28800)
SESSION_EXPIRY_SECONDS=28800

# Database (Phase 2 — replace in-memory store)
DATABASE_URL=postgresql://user:password@localhost:5432/inventory_db

# Security
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# AI / Doc automation (required for .github/workflows/update-docs.yml)
ANTHROPIC_API_KEY=sk-ant-...
